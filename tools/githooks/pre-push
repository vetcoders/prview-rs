#!/bin/sh
set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

MODE="${PRVIEW_GATE_HOOK_MODE:-advisory}"
STRICT_FLAG=""
BLOCKING=1

case "$MODE" in
  advisory|shadow)
    BLOCKING=0
    ;;
  warn)
    ;;
  strict|block)
    STRICT_FLAG="--strict"
    ;;
  *)
    echo "PRVIEW_GATE_HOOK_MODE must be one of: advisory, shadow, warn, strict, block" >&2
    exit 3
    ;;
esac

echo "=== prview pre-push gate ==="
echo "Mode: $MODE"

if ! command -v prview >/dev/null 2>&1; then
  echo "prview is required for this hook. Run 'make install-bin' or 'cargo install prview --locked --force'." >&2
  if [ "$BLOCKING" -eq 0 ]; then
    echo "Advisory mode: allowing push despite missing prview." >&2
    exit 0
  fi
  exit 3
fi

set +e
if [ -n "$STRICT_FLAG" ]; then
  prview gate "$STRICT_FLAG"
else
  prview gate
fi
STATUS=$?
set -e

case "$STATUS" in
  0)
    echo "prview gate: PASS or accepted CONDITIONAL (exit 0)."
    ;;
  1)
    echo "prview gate: BLOCK (exit 1)." >&2
    ;;
  2)
    echo "prview gate: CONDITIONAL rejected by strict mode (exit 2)." >&2
    ;;
  3)
    echo "prview gate: internal/tooling error (exit 3)." >&2
    ;;
  *)
    echo "prview gate: unexpected exit code $STATUS." >&2
    ;;
esac

if [ "$BLOCKING" -eq 0 ]; then
  echo "Advisory mode: reporting only; push is not blocked."
  exit 0
fi

exit "$STATUS"
